<UserControl
  x:Class="Gallery.Views.OpenMethodView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=AvaloniaFluentUI"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:model="clr-namespace:Gallery.Models"
  xmlns:vm="using:Gallery.ViewModels"
  x:DataType="vm:OpenMethodViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.Caption">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="LineHeight" Value="20"/>
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Border.SurfaceCard">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="18"/>
    </Style>

    <Style Selector="Border.MethodCard">
      <Setter Property="MinWidth" Value="320"/>
      <Setter Property="MaxWidth" Value="360"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <Style Selector="ComboBox.MethodCombo">
      <Setter Property="MinWidth" Value="240"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Styles>

  <Grid>
    <Border Background="{Binding PageOverlayBrush}"/>

    <fui:SmoothScrollViewer Padding="32,28,32,32" Background="Transparent">
      <StackPanel Spacing="22">
      <fui:ContentDialog
        Name="Dialog"
        Title=""
        CloseButtonText=""
        Content=""
        DefaultButton="Primary"
        IsPrimaryButtonEnabled="True"
        IsVisible="False"
        PrimaryButtonText=""/>

      <StackPanel Spacing="8">
        <TextBlock
          FontSize="32"
          FontWeight="SemiBold"
          Text="{Binding Title}"/>
      </StackPanel>

      <Border
        Classes="SurfaceCard"
        Padding="24"
        Background="{Binding GlassPanelBackground}"
        BorderBrush="{Binding GlassPanelBorderBrush}">
        <StackPanel Spacing="18">
          <StackPanel Spacing="4">
            <TextBlock Classes="SectionTitle" Text="{Binding SectionTitle}"/>
            <TextBlock
              Classes="Caption"
              MaxWidth="760"
              Text="{Binding SectionDescription}"
              TextWrapping="Wrap"/>
            <WrapPanel ItemSpacing="8" LineSpacing="8">
              <Button
                Click="OnRegisterSystemEntryClicked"
                Content="{Binding RegisterSystemEntryButton}"/>
              <Button
                Click="OnRefreshCurrentClicked"
                Content="{Binding RefreshCurrentButton}"/>
            </WrapPanel>
            <Border
              Margin="0,6,0,0"
              Padding="12,10"
              Background="{Binding InnerPanelBackground}"
              BorderBrush="{Binding InnerPanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="12">
              <StackPanel Spacing="4">
                <TextBlock
                  FontSize="12"
                  FontWeight="SemiBold"
                  Opacity="0.72"
                  Text="{Binding SystemEntryStatusLabel}"/>
                <TextBlock
                  Classes="Caption"
                  Text="{Binding SystemEntryStatusMessage}"
                  TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <ItemsControl ItemsSource="{Binding Entries}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel ItemSpacing="16" LineSpacing="16"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="model:OpenMethodEntryModel">
                <Border
                  Classes="MethodCard"
                  Background="{Binding $parent[UserControl].DataContext.MethodCardBackground}"
                  BorderBrush="{Binding $parent[UserControl].DataContext.MethodCardBorderBrush}">
                  <StackPanel Spacing="12">
                    <Border
                      Padding="12,10"
                      Background="{Binding $parent[UserControl].DataContext.InnerPanelBackground}"
                      BorderBrush="{Binding $parent[UserControl].DataContext.InnerPanelBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon
                          Width="18"
                          Height="18"
                          VerticalAlignment="Center"
                          Data="{x:Static fi:FluentIcon.Document}"/>
                        <TextBlock
                          VerticalAlignment="Center"
                          FontSize="15"
                          FontWeight="SemiBold"
                          Text="{Binding Title}"/>
                      </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                      <TextBlock Classes="Caption" Text="{Binding Extensions}"/>
                      <TextBlock Classes="Caption" Text="{Binding Description}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding $parent[UserControl].DataContext.ComboLabel}"/>
                      <ComboBox
                        Classes="MethodCombo"
                        ItemsSource="{Binding TargetOptions}"
                        SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                        SelectionChanged="OnTargetSelectionChanged">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="model:OpenMethodTargetOption">
                            <TextBlock Text="{Binding Label}"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <WrapPanel ItemSpacing="8" LineSpacing="8">
                        <Button
                          Name="RR"
                          Click="OnShowCustomDialog"
                          Content="{Binding $parent[UserControl].DataContext.ConfirmApplyButton}"
                          IsEnabled="{Binding HasPendingChange}"/>
                        <Button
                          Click="OnTestOpenClicked"
                          Content="{Binding $parent[UserControl].DataContext.TestOpenButton}"/>
                      </WrapPanel>
                    </StackPanel>

                    <Border
                      Padding="12,10"
                      Background="{Binding $parent[UserControl].DataContext.InnerPanelBackground}"
                      BorderBrush="{Binding $parent[UserControl].DataContext.InnerPanelBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                      <StackPanel Spacing="4">
                        <TextBlock
                          FontSize="12"
                          FontWeight="SemiBold"
                          Opacity="0.72"
                          Text="{Binding $parent[UserControl].DataContext.CurrentTargetLabel}"/>
                        <TextBlock FontSize="14" Text="{Binding CurrentTargetLabel}"/>
                        <TextBlock
                          Classes="Caption"
                          IsVisible="{Binding HasStatusMessage}"
                          Text="{Binding StatusMessage}"
                          TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
      <Border Height="96"/>
      </StackPanel>
    </fui:SmoothScrollViewer>
  </Grid>
</UserControl>
