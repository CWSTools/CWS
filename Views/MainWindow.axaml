<view:FluentWindow
  x:Class="Gallery.Views.MainWindow"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ani="clr-namespace:AvaloniaFluentUI.Media.Animation;assembly=AvaloniaFluentUI"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=AvaloniaFluentUI"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=AvaloniaFluentUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:Gallery.Controls"
  xmlns:view="clr-namespace:AvaloniaFluentUI.Windowing;assembly=AvaloniaFluentUI"
  xmlns:vm="using:Gallery.ViewModels"
  Title="{Binding Title}"
  Width="1200"
  Height="800"
  MinWidth="750"
  MinHeight="500"
  d:DesignHeight="1080"
  d:DesignWidth="1920"
  x:DataType="vm:MainWindowViewModel"
  Icon="/Assets/app.ico"
  IconSize="20"
  TitleBarMargin="40 0 0 0"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d">
  <!--  BorderBrush="{Binding BorderBrush}"  -->
  <!--  BorderThickness="{Binding BorderWidth}"  -->

  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Styles>
    <!-- <Style Selector="Button.NavigationItem"> -->
    <!--     <Setter Property="Height" Value="35"/> -->
    <!--     <Setter Property="VerticalContentAlignment" Value="Center"/> -->
    <!--     <Setter Property="HorizontalAlignment" Value="Stretch"/> -->
    <!--     <Setter Property="CornerRadius" Value="5"/> -->
    <!--     <Setter Property="Background" Value="Transparent"/> -->
    <!--     ~1~ <Setter Property="BorderBrush" Value="DeepPink"/> @1@ -->
    <!-- </Style> -->

    <!--  Hover  -->
    <!-- <Style Selector="Button.NavigationItem:pointerover /template/ContentPresenter"> -->
    <!--     <Setter Property="Background" Value="#e7eaef"/> -->
    <!-- </Style> -->
    <!--    -->
    <!-- <Style Selector="Button.NavigationItem:pressed /template/ContentPresenter"> -->
    <!--     <Setter Property="Opacity" Value="0.85"/> -->
    <!-- </Style> -->

    <!-- <Style Selector="Button.NavigationItem[IsSelected=true] /template/ContentPresenter"> -->
    <!-- <Setter Property="Background" Value="#eaeaea" /> -->
    <!-- </Style> -->

    <!-- <Style Selector="TransitioningContentControl"> -->
    <!-- <Setter Property="CornerRadius" Value="12 0 0 0" /> -->
    <!-- <Setter Property="Background" Value="#50F7F9FC" /> -->
    <!-- <Setter Property="BorderThickness" Value="1" /> -->
    <!-- <Setter Property="BorderBrush" Value="#E2E5E9" /> -->
    <!-- <Setter Property="ClipToBounds" Value="True" /> -->
    <!-- </Style> -->
    <Style Selector="UserControl">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Window">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="fui|NavigationViewItem.Icon /template/ Viewbox#IconBox ContentPresenter#Icon fui|FluentPathIcon">
      <Setter Property="Margin" Value="3"/>
    </Style>

    <Style Selector="view|AppSplashScreen">
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
  </Window.Styles>


  <!-- <Window.Background> -->
  <!-- <ImageBrush Source="avares://CWSTool/Assets/Images/5.jpg" Stretch="UniformToFill"></ImageBrush> -->
  <!-- </Window.Background> -->

  <view:FluentWindow.TitleBarContent>
    <Grid ColumnDefinitions="*, Auto, Auto">
      <fui:SearchTextBox
        Width="256"
        Margin="0,10,0,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        PlaceholderText="{Binding SearchWatermark}"/>

      <fui:ToolButton
        Name="PinButton"
        Grid.Column="1"
        Width="46"
        Height="45"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Classes="Transparent"
        Click="OnToggleTopmost"
        Content="{x:Static fi:FluentIcon.Pin}"
        Tag="noTopmost"/>
      <fui:ToolButton
        Grid.Column="2"
        Width="46"
        Height="45"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Classes="Transparent"
        Command="{Binding ToggleThemeCommand}"
        Content="M15 3v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703zM8 7q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM27 4q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM24 16v0.156q0 1.625-0.648 3.055t-1.75 2.492-2.547 1.68-3.055 0.617q-1.656 0-3.117-0.625t-2.547-1.711-1.711-2.547-0.625-3.117 0.625-3.117 1.711-2.547 2.547-1.711 3.117-0.625 3.117 0.625 2.547 1.711 1.711 2.547 0.625 3.117zM16 22h0.125q1.219 0 2.289-0.484t1.867-1.313 1.258-1.914 0.461-2.289-0.461-2.289-1.258-1.914-1.867-1.313-2.289-0.484h-0.125v12zM3 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM31 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM7 24q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM28 27q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM17 29v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703z"
        ToolTip.Tip="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[ToggleTheme]}"/>
    </Grid>
  </view:FluentWindow.TitleBarContent>

  <Grid Margin="0,0,0,0">

    <!--  IsHitTestVisible 鼠标击中  -->
    <Image
      x:Name="BackgroundImage"
      Grid.RowSpan="2"
      Grid.ColumnSpan="2"
      IsHitTestVisible="False"
      IsVisible="False"
      Opacity="0.3"
      Stretch="UniformToFill"/>

    <!--  Grid.Row="0"  -->
    <!--  Grid.ColumnSpan="2"  -->
    <!--  Margin="10,10,10,0"  -->
    <!--  ColumnDefinitions="Auto, Auto"  -->
    <!--  ColumnSpacing="5">  -->

    <!--  <ui:ToolButton  -->
    <!--  Classes="ReturnButton"  -->
    <!--  x:Name="ReturnButton"  -->
    <!--  Grid.Column="0"  -->
    <!--  Width="30"  -->
    <!--  Height="30"  -->
    <!--  CornerRadius="4"  -->
    <!--  Command="{Binding GoBackCommand}" />  -->
    <!--  <Image Grid.Column="0" Width="30" Height="30"  -->
    <!-- Source="avares://Demo/Assets/Icons/LeftArrow_black.png"></Image> -->

    <!-- <Image Grid.Column="1" Source="/Assets/avalonia-logo.ico" /> -->
    <!-- <Label Grid.Column="2" Content="Avalonia" /> -->

    <!-- <Image Grid.Column="0" Source="/Assets/app.ico"/> -->
    <!--  <Label  -->
    <!--  Grid.Column="1"  -->
    <!--  VerticalAlignment="Top"  -->
    <!--  Content="{Binding $parent[Window].Title}"/>  -->
    <!-- </Grid> -->

    <fui:NavigationView
      Name="NavigationView"
      Grid.Column="0"
      AlwaysShowHeader="False"
      BackCommand="{Binding GoBackCommand}"
      Background="Transparent"
      IsBackButtonVisible="True"
      IsBackEnabled="True"
      IsSettingsVisible="True"
      PaneDisplayMode="Auto"
      PaneFooterSeparatorIsVisible="True"
      SelectedItem="{Binding NavigationViewSelectedItem, Mode=TwoWay}">

      <fui:NavigationView.AutoCompleteBox>
        <fui:SearchTextBox PlaceholderText="{Binding SearchWatermark}"/>
      </fui:NavigationView.AutoCompleteBox>

      <fui:NavigationView.PaneFooter>
        <Border
          Margin="12,0,12,12"
          Padding="12"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlStrokeColorDefault}"
          BorderThickness="1"
          CornerRadius="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_PaneFooterTitle]}"/>
            <TextBlock
              FontSize="12"
              Opacity="0.68"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_PaneFooterSubtitle]}"
              TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </fui:NavigationView.PaneFooter>

      <fui:NavigationView.MenuItems>
        <fui:NavigationViewItem
          IsSelected="True"
          Tag="Home"
