              <TextBlock Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_NavWorkbenchTitle]}"/>
              <TextBlock FontSize="12" Opacity="0.62" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_NavWorkbenchSubtitle]}"/>
            </StackPanel>
          </fui:NavigationViewItem.Content>
        </fui:NavigationViewItem>

