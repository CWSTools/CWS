              <TextBlock FontSize="12" Opacity="0.62" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_NavOpenMethodSubtitle]}"/>
            </StackPanel>
          </fui:NavigationViewItem.Content>
        </fui:NavigationViewItem>

