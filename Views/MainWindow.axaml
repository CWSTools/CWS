          <fui:NavigationViewItem.Content>
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_NavAboutTitle]}"/>
              <TextBlock FontSize="12" Opacity="0.62" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MW_NavAboutSubtitle]}"/>
            </StackPanel>
          </fui:NavigationViewItem.Content>
        </fui:NavigationViewItem>
      </fui:NavigationView.MenuItems>

      <fui:NavigationView.Content>
        <fui:StackContent Content="{Binding CurrentViewModel}"/>
      </fui:NavigationView.Content>
    </fui:NavigationView>
  </Grid>

</view:FluentWindow>
