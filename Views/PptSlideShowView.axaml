<UserControl
  x:Class="Gallery.Views.PptSlideShowView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=AvaloniaFluentUI"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:vm="using:Gallery.ViewModels"
  x:DataType="vm:PptSlideShowViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.Caption">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="LineHeight" Value="20"/>
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Border.SurfaceCard">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="18"/>
    </Style>

    <Style Selector="Border.InfoPanel">
      <Setter Property="Padding" Value="16"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <Style Selector="Button.ControlButton">
      <Setter Property="MinWidth" Value="116"/>
      <Setter Property="Padding" Value="16,9"/>
    </Style>
  </UserControl.Styles>

  <Grid>
    <Border Background="{Binding PageOverlayBrush}"/>

    <fui:SmoothScrollViewer Padding="32,28,32,32" Background="Transparent">
      <StackPanel Spacing="22">
        <StackPanel Spacing="8">
          <TextBlock
            FontSize="32"
            FontWeight="SemiBold"
            Text="{Binding Title}"/>
          <TextBlock
            Classes="Caption"
            MaxWidth="760"
            FontSize="15"
            LineHeight="24"
            Text="{Binding PageDescription}"
            TextWrapping="Wrap"/>
        </StackPanel>

        <Border
          Classes="SurfaceCard"
          Padding="24"
          Background="{Binding GlassPanelBackground}"
          BorderBrush="{Binding GlassPanelBorderBrush}">
          <StackPanel Spacing="20">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
              <Border
                Classes="InfoPanel"
                Background="{Binding InnerPanelBackground}"
                BorderBrush="{Binding InnerPanelBorderBrush}">
                <StackPanel Spacing="6">
                  <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.72"
                    Text="{Binding ConnectionStatusTitle}"/>
                  <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Text="{Binding ConnectionLabel}"
                    TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border
                Grid.Column="1"
                Classes="InfoPanel"
                Background="{Binding InnerPanelBackground}"
                BorderBrush="{Binding InnerPanelBorderBrush}">
                <StackPanel Spacing="6">
                  <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.72"
                    Text="{Binding CurrentDeckTitle}"/>
                  <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Text="{Binding ActiveFileLabel}"
                    TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border
                Grid.Column="2"
                Classes="InfoPanel"
                Background="{Binding InnerPanelBackground}"
                BorderBrush="{Binding InnerPanelBorderBrush}">
                <StackPanel Spacing="6">
                  <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.72"
                    Text="{Binding SlideCounterTitle}"/>
                  <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="{Binding SlideCounter}"/>
                </StackPanel>
              </Border>
            </Grid>

            <WrapPanel ItemSpacing="10" LineSpacing="10">
              <Button
                Classes="ControlButton"
                Click="OnOpenPresentationClicked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="{x:Static fi:FluentIcon.Document}"/>
                  <TextBlock Text="{Binding OpenButton}"/>
                </StackPanel>
              </Button>

              <Button
                Classes="ControlButton"
                Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="{x:Static fi:FluentIcon.Sync}"/>
                  <TextBlock Text="{Binding RefreshButton}"/>
                </StackPanel>
              </Button>

              <Button
                Classes="ControlButton"
                Click="OnOpenFloatingWindowClicked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="{x:Static fi:FluentIcon.Video}"/>
                  <TextBlock Text="{Binding FloatingWindowButton}"/>
                </StackPanel>
              </Button>

              <Button
                Classes="ControlButton"
                Command="{Binding StartSlideShowCommand}"
                IsEnabled="{Binding CanStartSlideShow}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="{x:Static fi:FluentIcon.Play}"/>
                  <TextBlock Text="{Binding StartButton}"/>
                </StackPanel>
              </Button>

              <Button
                Classes="ControlButton"
                Command="{Binding EndSlideShowCommand}"
                IsEnabled="{Binding CanControlSlideShow}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="M6 6h20v20h-20z"/>
                  <TextBlock Text="{Binding EndButton}"/>
                </StackPanel>
              </Button>
            </WrapPanel>

            <Border
              Classes="InfoPanel"
              Background="{Binding InnerPanelBackground}"
              BorderBrush="{Binding InnerPanelBorderBrush}">
              <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="10">
                <Button
                  Classes="ControlButton"
                  Command="{Binding PreviousCommand}"
                  IsEnabled="{Binding CanControlSlideShow}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Width="16" Height="16" Data="M22 6l-10 10 10 10z"/>
                    <TextBlock Text="{Binding PreviousButton}"/>
                  </StackPanel>
                </Button>

                <Button
                  Grid.Column="1"
                  Classes="ControlButton"
                  Command="{Binding NextCommand}"
                  IsEnabled="{Binding CanControlSlideShow}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Width="16" Height="16" Data="M10 6l10 10-10 10z"/>
                    <TextBlock Text="{Binding NextButton}"/>
                  </StackPanel>
                </Button>

                <StackPanel
                  Grid.Column="2"
                  MinWidth="160"
                  Spacing="6">
                  <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.72"
                    Text="{Binding TargetSlideLabel}"/>
                  <fui:NumberBox
                    Minimum="1"
                    SpinButtonPlacementMode="Compact"
                    Value="{Binding TargetSlideNumber, Mode=TwoWay}"/>
                </StackPanel>

                <Button
                  Grid.Column="3"
                  Classes="ControlButton"
                  VerticalAlignment="Bottom"
                  Command="{Binding GoToSlideCommand}"
                  IsEnabled="{Binding CanControlSlideShow}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Width="16" Height="16" Data="{x:Static fi:FluentIcon.Send}"/>
                    <TextBlock Text="{Binding GotoButton}"/>
                  </StackPanel>
                </Button>

                <TextBlock
                  Grid.Column="4"
                  Classes="Caption"
                  VerticalAlignment="Bottom"
                  Text="{Binding StatusMessage}"
                  TextWrapping="Wrap"/>
              </Grid>
            </Border>
          </StackPanel>
        </Border>

        <Border Height="96"/>
      </StackPanel>
    </fui:SmoothScrollViewer>
  </Grid>
</UserControl>
